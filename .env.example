# Copy to .env. Defaults bind host ports to 17899/19091 so this can be tested
# beside the current two-container setup. Use HOST_MIXED_PORT=17898 only when
# replacing the old container.

SUB_URL=https://example.com/your-subscription?clash=3
SOCKS_SERVER=192.0.2.10
SOCKS_PORT=1080
SOCKS_USERNAME=your-username
SOCKS_PASSWORD=your-password

HOST_MIXED_PORT=17899
HOST_CONTROLLER_PORT=19091
MIXED_PORT=17898
CONTROLLER_SECRET=change-this-long-random-secret

SUB_UPDATE_INTERVAL=3600
CHAIN_TEST_URL=https://claude.ai/
# Watchdog measures each full chain against CHAIN_TEST_URL:
# local container -> subscription node -> final SOCKS5 -> CHAIN_TEST_URL.
WATCH_INTERVAL_SEC=60
WATCH_TIMEOUT_MS=6000
WATCH_CONCURRENCY=16
SWITCH_MARGIN_MS=150
SWITCH_STABLE_ROUNDS=2
MIHOMO_LOG_LEVEL=info
SUB_FETCH_PROXY=
